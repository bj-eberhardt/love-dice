{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist/types",
    "paths": {
      "@/*": ["./src/*"]
    },
    "strict": true,
    "target": "ES2022",
    "types": ["vite/client"]
  },
  "include": ["src", "vite.config.ts"]
}
